# Default: LF in the repo, native in the working tree.
* text=auto eol=lf

# Force LF for everything that's executed cross-platform.
*.sh           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.js           text eol=lf
*.jsx          text eol=lf
*.css          text eol=lf
Dockerfile     text eol=lf

# Lockfiles — keep diffs deterministic.
package-lock.json text eol=lf
*.lock           text eol=lf

# Binary types — never text-converted.
*.png   binary
*.jpg   binary
*.ico   binary
