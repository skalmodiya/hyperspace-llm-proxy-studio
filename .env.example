HYPERSPACE_PROXY_URL=http://localhost:6655

# API Key sent to the proxy as `Authorization: Bearer <API_KEY>`.
# Server-side only. Never exposed to the browser.
HYPERSPACE_API_KEY=

# Request behaviour
HYPERSPACE_REQUEST_TIMEOUT_MS=60000
HYPERSPACE_RETRY_COUNT=2

# Optional: log raw upstream payloads (server console only)
HYPERSPACE_DEBUG=false

# Public app metadata (safe to expose)
NEXT_PUBLIC_APP_NAME=Hyperspace LLM Proxy Studio

# Shared admin token (>=16 chars). PATCH /api/settings requires either:
#   - on BTP: a valid XSUAA JWT with the Admin scope, OR
#   - off BTP: this value passed via the `x-studio-admin-token` header.
# The Settings UI auto-attaches it from localStorage. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(24).toString('base64url'))"
STUDIO_ADMIN_TOKEN=
