# Docker-specific environment overrides.
#
# When running locally: copy this to docker.env and fill in the API key.
#   cp docker.env.example docker.env
# Then `docker compose --env-file docker.env up` reads it. Or rely on the
# default lookup — compose will read docker.env automatically if it exists
# in the same directory as docker-compose.yml.
#
# The proxy URL here uses host.docker.internal because, inside the container,
# `localhost` is the container itself, not your host machine. This file
# overrides .env.local's localhost value when running under Docker.

HYPERSPACE_PROXY_URL=http://host.docker.internal:6655
HYPERSPACE_API_KEY=
HYPERSPACE_REQUEST_TIMEOUT_MS=60000
HYPERSPACE_RETRY_COUNT=2
HYPERSPACE_DEBUG=false
NEXT_PUBLIC_APP_NAME=Hyperspace LLM Proxy Studio
